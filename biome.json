{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": ["!node_modules", "!.next", "!dist", "!build"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 60 }
        },
        "noForEach": "warn",
        "noVoid": "warn"
      },
      "correctness": {
        "useImageSize": "off",
        "useExhaustiveDependencies": "warn",
        "noNestedComponentDefinitions": "warn",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "warn"
      },
      "style": {
        "noNestedTernary": "warn",
        "useCollapsedElseIf": "warn",
        "useCollapsedIf": "warn",
        "noNonNullAssertion": "warn",
        "useFilenamingConvention": "warn"
      },
      "suspicious": {
        "noUnknownAtRules": "off",
        "noAlert": "warn",
        "noEvolvingTypes": "warn",
        "noEmptyBlockStatements": "warn",
        "noArrayIndexKey": "warn",
        "noDocumentCookie": "warn"
      },
      "security": { "noDangerouslySetInnerHtml": "off" },
      "a11y": {
        "useKeyWithClickEvents": "warn",
        "noNoninteractiveElementInteractions": "warn",
        "noStaticElementInteractions": "warn",
        "useButtonType": "warn",
        "useFocusableInteractive": "warn",
        "useSemanticElements": "warn"
      },
      "performance": {
        "useTopLevelRegex": "warn",
        "noNamespaceImport": "warn"
      }
    },
    "domains": { "next": "recommended", "react": "recommended" }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next"
  ]
}
